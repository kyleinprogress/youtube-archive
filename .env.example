# Copy to .env and edit. Read by compose.yml at container startup.

# Filesystem ownership the container should write as. Match the uid/gid that
# owns your media dataset on the host (TrueNAS: `id <your-user>` from a shell).
PUID=1000
PGID=1000

# Where the archive lives on the host. Bind-mounted to /data inside the
# container. Point this at your media dataset on TrueNAS, e.g.
# /mnt/Hellcat/Media/Youtube. Defaults to ./data next to this compose file.
DATA_DIR=./data

# Supercronic schedule for the daily sync. Standard 5-field cron expression.
# Default: 03:00 every day.
ARCHIVE_CRON=0 3 * * *

# --serve bind/port. SERVE_PORT is also used as the host-side published port.
SERVE_HOST=0.0.0.0
SERVE_PORT=8765
